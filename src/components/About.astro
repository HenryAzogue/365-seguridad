---
import SpanText from "./SpanText.astro";

---

<section class="about">
  <div class="about-content">
    <SpanText spanColor={false} spanText="Sobre nosotros"/>
    <h2 class="about-title">Tu seguridad y entretenimiento, en un solo lugar.</h2>
    <div class="about-paragraph">
      <p class="paragraph">Más que seguridad: paz mental. <br/>
        Diseñamos sistemas a tu medida para tu hogar o negocio, y sumamos internet y TV de alta calidad, todo en un solo servicio.
      </p>
    </div>
    <div class="about-bento">
      <div class="bento-camera">
        <p class="img-hero-title">Cercos Eléctricos</p>
        <p class="img-hero-title">Camaras</p>
        <p class="img-hero-title">Alarmas</p>
      </div>

      <div class="bento-option">
        <div class="option-subtitle">
          <p class="option-text-p">65 Canales en el plan Televisión por cable </p>
        </div>
        <div class="option-text">
          <p class="option-text-p2">+ Internet 100% Fibra óptica</p>
          <div class="option-img"></div>
        </div>
      </div>

      <div class="bento-family"></div>
    </div>
  </div>
</section>

<style>
  .about{
    background-color: var(--color-back);

    & .about-content{
      max-width: 1100px;
      margin:0 auto;
      padding: 5rem 1rem ;
    }
  }
  .about-title{
    max-width: 777px;
    color: var(--color-text);
    font-family: var(--font-principal);
    font-size: var(--fs-subtitle);
    font-weight: 500;
  }
  .about-paragraph{
    color: var(--color-span-text);
    font-family: var(--font-normal);
    font-size: var(--fs-text);

    display: flex;
    justify-content: end;
    & .paragraph{
      max-width: 650px;
      padding: 1rem 0;
    }
  }
  .about-bento{
    --valor-box: clamp(15.63rem, calc(10.423rem + 1.627vw), 31.25rem);
    --valor-box1: clamp(15.63rem, 26.0333vw + 10.4233rem, 31.25rem);
    margin-top: 5rem;
    display: grid;
    grid-auto-columns: 1fr 1fr;
    grid-auto-rows: var(--valor-box1);
    gap: 1rem;
    grid-template-areas: 
    "bento-camera bento-camera"
    "bento-option bento-family";
  }
  .bento-camera{
    grid-area: bento-camera;
    border-radius: 1rem;
    background-image: url(../../src/assets/bento-camera.avif);
    background-size: cover;
    background-position: 50% 50%;
    color: var(--color-back);
    font-size: var(--fs-bento-title);
    padding: 2rem;

    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 5% cover 50%;
  }
  .bento-option{
    border-radius: 1rem;
    border: 1px  solid rgba(51,51,51,0.5);
    grid-area: bento-option;

    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center ;
    gap: 1rem;

    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 5% cover 50%;

    & .option-subtitle{ 
      margin-top: 3rem;

      grid-area: option-subtitle; 
      text-align: center;
    }

    & .option-text{ 
      grid-area: option-text; 

      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      width: 100%;

      & .option-text-p2{
        width: 250px;
        margin-left: 9px;
        color: var(--color-span-text);
        font-size: var(--fs-bento-title);
      }

      & .option-img{
        padding-left: 1rem;
        grid-area: option-img;
        border-radius: 1rem;
        background-image: url(../../src/assets/bento-internet.avif);
        background-size: cover;
        width: clamp(10.9375rem, 7.8125vw + 9.375rem, 15.625rem);
        height: clamp(10.9375rem, 7.8125vw + 9.375rem, 15.625rem);
      }
    }
  }
  .option-text-p{
    color: var(--color-span-text);
    font-size: var(--fs-bento-title);
  }
  .bento-family{
    grid-area: bento-family;
    border-radius: 1rem;
    width: 100%;
    height: 100%;
    background-image: url(../../src/assets/bento-family.avif);
    background-size: cover;

    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 5% cover 50%;
  }

   @keyframes reveal{
    from{
      opacity: 0;
      translate: 0 90px;
    }
    to{
      opacity: 1;
      translate: 0 0;
    }
  }

  @media (width <= 64em) {}
  @media (width <= 56em) {
    .about-bento{
      grid-template-areas: 
      "bento-camera"
      "bento-option"
      "bento-family";
    }
    .bento-camera{
      padding: 1rem;
    }
  }
  @media (width <= 42em) {
    .bento-option{
      gap: 10px;
      & .option-subtitle{
        padding-top: 0;
        margin-top: 1rem;
      }
      & .option-text{
        .option-text-p2{
          width: 112px;
        }
      }
    }
  }
</style>