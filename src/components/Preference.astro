---
import SpanText from "@components/SpanText.astro";
---

<section class="preference">
  <div class="preference-content">
    <SpanText
      spanText="¿Por qué elegirnos?"
      spanColor={false}
    />
    <h2 class="preference-title">
      Protegemos lo que <br /> más valoras
    </h2>

    <section class="card">
      <div class="card--n1" style="grid-area: card--n1">
        <p class="item-text">
          Espacios para la <br /> familia
        </p>
      </div>
      <div class="card--n2" style="grid-area: card--n2">
        <p class="item-text">Tranquilidad en el Trabajo</p>
      </div>
      <div class="card--n3" style="grid-area: card--n3">
        <p class="item-text">
          Conexión con los <br /> Tuyos
        </p>
      </div>
      <div class="card--n4" style="grid-area: card--n4">
        <p class="item-text">
          Seguimiento <br /> via teléfono
        </p>
      </div>
      <div class="card--n5" style="grid-area: card--n5">
        <p class="item-text">
          Rincones <br /> del Hogar
        </p>
      </div>
      <div class="card--n6" style="grid-area: card--n6">
        <p class="item-text">Comercios Seguros</p>
      </div>
    </section>
  </div>
</section>

<style>
  .preference {
    background-color: var(--color-back);
    padding-bottom: 4rem;

    .preference-content {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1rem;
    }
  }
  .preference-title {
    font-family: var(--font-principal);
    font-size: var(--fs-subtitle);
    font-weight: 500;
  }

  .card {
    color: var(--color-back);
    font-family: var(--font-normal);
    font-weight: 400;
    font-size: var(--fs-text);

    display: grid;
    grid-auto-columns: 1fr;
    grid-auto-rows: 300px 150px 150px 300px;
    gap: 1rem;
    grid-template-areas:
      "card--n1 card--n1 card--n2"
      "card--n3 card--n3 card--n2"
      "card--n3 card--n3 card--n6"
      "card--n4 card--n5 card--n6";
  }

  .card--n1 {
    box-shadow: 2px 3px 4px rgba(0, 0, 0, 0.25);
    display: flex;
    justify-content: end;
    padding: 1rem;
    background-image: url(../../src/assets/001-img.avif);
    background-size: cover;
    background-position: 50% 50%;
    border-radius: var(--border-radius);

    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 20% cover 50%;
  }
  .card--n2 {
    box-shadow: 2px 3px 4px rgba(0, 0, 0, 0.25);
    padding: 1rem;
    background-image: url(../../src/assets/002-img.avif);
    background-size: cover;
    background-position: 55% 95%;
    border-radius: var(--border-radius);

    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 20% cover 50%;
  }
  .card--n3 {
    box-shadow: 2px 3px 4px rgba(0, 0, 0, 0.25);
    display: flex;
    justify-content: end;
    padding: 1rem;
    background-image: url(../../src/assets/003-img.avif);
    background-size: cover;
    background-position: 90% 90%;
    border-radius: var(--border-radius);

    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 20% cover 50%;
  }
  .card--n4 {
    box-shadow: 2px 3px 4px rgba(0, 0, 0, 0.25);
    display: flex;
    align-items: end;

    padding: 1rem;
    background-image: url(../../src/assets/004-img.avif);
    background-size: cover;
    background-position: 50% 50%;
    border-radius: var(--border-radius);

    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 20% cover 50%;
  }
  .card--n5 {
    box-shadow: 2px 3px 4px rgba(0, 0, 0, 0.25);
    display: flex;
    align-items: end;

    padding: 1rem;
    background-image: url(../../src/assets/005-img.avif);
    background-size: cover;
    background-position: 50% 50%;
    border-radius: var(--border-radius);

    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 20% cover 50%;
  }
  .card--n6 {
    box-shadow: 2px 3px 4px rgba(0, 0, 0, 0.2);
    padding: 1rem;
    background-image: url(../../src/assets/006-img.avif);
    background-size: cover;
    background-position: 15% 50%;
    border-radius: var(--border-radius);

    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 20% cover 50%;
  }

  @keyframes reveal{
    from{
      opacity: 0;
      translate: 0 100px;
      scale: .5;
    }
    to{
      opacity: 1;
      translate: 0 0;
      scale: 1;
    }
  }

  @media (width <= 64em) {
    .preference-content {
      & .card {
        grid-auto-rows: 300px 150px 150px 300px;
        gap: 1rem;
        grid-template-areas:
          "card--n1 card--n1 card--n2"
          "card--n3 card--n3 card--n2"
          "card--n3 card--n3 card--n6"
          "card--n4 card--n5 card--n6";
      }
      & .card--n3 {
        background-position: 50% 90%;
      }
    }
  }
  @media (width <= 56em) {
    .preference-content {
      & .card {
        grid-auto-rows: 300px;
        grid-template-areas:
          "card--n1 card--n1"
          "card--n3 card--n3"
          "card--n2 card--n2"
          "card--n4 card--n5"
          "card--n6 card--n6";
      }
      & .card--n2 {
        background-position: 50% 60%;
      }
    }
  }
  @media (width <= 42em) {
    .preference-content {
      & .card {
        grid-template-areas:
          "card--n1"
          "card--n3"
          "card--n2"
          "card--n4"
          "card--n5"
          "card--n6";
      }
      & .card--n2 {
        background-position: 50% 60%;
      }
    }
  }
</style>
