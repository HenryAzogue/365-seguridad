---
import LogoIcon from "@icons/Logo.astro";
---

<header class="header">
  <div class="header-content">
    <a 
      href="#" 
      referrerpolicy="no-referrer" 
      target="_self" 
      aria-lavel="365 Seguridad" 
      class="content-logo"
    >
      <div class="content-icon">
        <LogoIcon />
      </div>
      365 Seguridad
    </a>

    <nav class="nav">
      <ul class="nav-list">
        <li class="nav-item">
          <a 
            aria-label="Direcciona a la sección de inicio" 
            href="#inicio" 
            class="nav-link"
          >Inicio
          </a>
        </li>
        <li class="nav-item">
          <a 
            aria-label="Direcciona a la sección de servicios" 
            href="#servicios" 
            class="nav-link"
          >Servicios
          </a>
        </li>
        <li class="nav-item">
          <a 
            aria-label="Direcciona a la sección de promociones" 
            href="#promociones" 
            class="nav-link"
          >Promociones
          </a>
        </li>
        <li class="nav-item">
          <a 
            aria-label="Direcciona a la sección de contacto" 
            href="#contactame" 
            class="nav-link"
          >Contacto
          </a>
        </li>
        <li class="nav-item nav-item--movil">
          <a 
            aria-label="Direcciona a la página de Conocenos" 
            href=""
            target="_blank"
            rel="noreferrer noopener" 
            class="nav-link" 
          >
            Conocenos
          </a>
        </li>
        <li class="nav-item nav-item--movil">
          <a 
            aria-label="Direcciona a la página de Blog" 
            href=""
            target="_blank"
            rel="noreferrer noopener" 
            class="nav-link" 
          >
          Blog
          </a>
        </li>
        <li class="nav-item nav-item--movil">
          <a 
            aria-label="Direcciona a la página de terminos" 
            href=""
            target="_blank"
            rel="noreferrer noopener" 
            class="nav-link" 
          >
          Terminos
          </a>
        </li>
        <li class="nav-item nav-item--movil">
          <a 
            aria-label="Direcciona a la página de condiciones" 
            href=""
            target="_blank"
            rel="noreferrer noopener" 
            class="nav-link" 
          >
          Condiciones
          </a>
        </li>
        <li class="nav-item--movil">
          <div class="rrss">
            <a 
              aria-label="Direcciona a la página de facebook" 
              href="https://www.facebook.com/people/365-Televisi%C3%B3n-y-Seguridad-Electr%C3%B3nica/61554364868800/"
              target="_blank"
              rel="noreferrer noopener"
              class="alink" 
              >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                fill="currentColor"
                class="bi bi-facebook"
                viewBox="0 0 16 16"
              >
                <path
                  d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"
                ></path>
              </svg>
            </a>
          </div>
        </li>
      </ul>
    </nav>
    <div class="hamburger">
      <div class="bar"></div>
      <div class="bar"></div>
      <div class="bar"></div>
    </div>

    <details class="menu-tini">
      <summary class="menu-title">
        <div class="poinst"></div>
        <div class="poinst"></div>
        <div class="poinst"></div>
      </summary>
      <a href=""></a>
      <div class="menu-content">
        <a 
          aria-label="Direcciona a la seccion de conocenos" 
          href="https://www.facebook.com/people/365-Televisi%C3%B3n-y-Seguridad-Electr%C3%B3nica/61554364868800/" 
          target="_blank"
          rel="noreferrer noopener"
          class="menu-option" 
        >Conocenos
        </a>
        <!-- <a href="/" class="menu-option">Nuestro Blog</a> -->
        <a 
          aria-label="Direcciona a la página de Terminos" 
          href="/" 
          target="_blank"
          rel="noreferrer noopener"
          class="menu-option" 
        >Terminos
        </a>
        <a 
          aria-label="Direcciona a la página de Condiciones" 
          href="/" 
          target="_blank"
          rel="noreferrer noopener"
          class="menu-option" 
        >Condiciones
        </a>
        <div class="rrss">
          <a 
            aria-label="Direcciona a la página de facebook" 
            href="https://www.facebook.com/people/365-Televisi%C3%B3n-y-Seguridad-Electr%C3%B3nica/61554364868800/"
            target="_blank"
            rel="noreferrer noopener"
            class="alink" 
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              fill="currentColor"
              class="bi bi-facebook"
              viewBox="0 0 16 16"
            >
              <path
                d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </details>
  </div>
</header>

<style>
  .header {
    background: var(--color-principal);
    border-radius: var(--border-radius);

    position: sticky;
    max-width: 1440px;
    height: 47px;
    margin: 0 auto;
    top: 0px;

    animation: enhance-header linear both;
    animation-timeline: scroll(root);
    animation-range: 0 150px;

    z-index: 2;
  }

  @keyframes enhance-header {
    to {
      border-radius: 0 0 var(--border-radius)
        var(--border-radius);
      max-width: 1250px;
    }
  }
  .header-content {
    border-radius: 16px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;

    /*max-width: 1024px;*/

    padding: 2px 1rem;
    margin: 3px auto;
  }
  .content-logo{
    display: flex;
    align-items: center;
    gap: 3px;
    color: var(--color-back);
    font-family: var(--font-principal);
    font-weight: 400;
    font-size: 1rem;

  }

  .content-icon{
    width: 35px;
    height: 35px;
  }

  .nav {
    color: var(--color-back);
    font-family: var(--font-normal);
    font-weight: 400;
    padding-top: 3px;
    transition: all 0.3s ease-in-out;
  }

  .nav-list {
    display: flex;
    column-gap: 1rem;
  }

  .nav-item {
  }

  .nav-item--movil {
    display: none;
  }

  .nav-link {
    transition: color 0.4s ease-out;
  }

  .nav-link:hover,
  .nav-link:focus {
    color: var(--color-secondary);
  }

  .hamburger {
    display: none;
    cursor: pointer;
  }

  .bar {
    border-radius: 55px;
    height: 3px;
    width: 27px;
    background: var(--color-back);
    margin: 5px 0;
    opacity: 0.9;
    transition: all 0.3s ease-in-out;
  }

  .nav-open {
    transform: translate(0) !important;
  }

  .hamburger-open .bar:nth-child(1) {
    transform: translateY(8px) rotate(50deg);
  }

  .hamburger-open .bar:nth-child(2) {
    opacity: 0;
  }

  .hamburger-open .bar:nth-child(3) {
    transform: translateY(-8px) rotate(-50deg);
  }

  .menu-tini {
    cursor: pointer;
    position: relative;
    padding-top: 3px;
    margin-right: 9px;
  }

  .menu-title {
    list-style: none;
    display: flex;
    gap: 3px;
  }

  .poinst {
    border-radius: 100%;
    background: var(--color-back);
    width: 5px;
    height: 5px;
  }

  .menu-content {
    background: var(--color-principal);
    border: solid 1px var(--color-back);
    border-radius: 15px;

    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;

    width: 200px;
    padding: 1rem 0;
    position: absolute;
    left: -9.55rem;
    top: 1rem;
  }

  .menu-option {
    color: var(--color-back);
    font-weight: 500;
    border-bottom: solid 1px var(--color-back);
    font-family: var(--font-normal);
    font-size: 16px;
    text-align: center;
    padding-bottom: 5px;
    width: 100%;

    transition: color 0.4s ease-out;
  }

  .menu-option:hover,
  .menu-option:focus {
    color: var(--color-secondary);
  }

  @keyframes sub-menutini {
    to {
      background: var(--color-mb);
      border: solid 1px var(--color-b1);
      border-radius: 25px;
      max-width: 1024px;
    }
  }
  .rrss {
    display: flex;
    gap: 1rem;
    & .alink {
      padding-bottom: 10px;
      color: var(--color-back);
      width: 32px;
      height: 32px;

      & svg {
        width: 100%;
        height: 100%;
      }
    }
  }
  .alink {
    transition: color 0.4s ease-out;
  }
  .alink:hover,
  .alink:focus {
    color: var(--color-secondary);
  }

  @media (width <= 768px) {
    .header {
      background: var(--color-principal);
    }
    .nav {
      border: solid 1px var(--color-back);
      border-radius: 15px;
      background: var(--color-principal);
      position: fixed;
      top: 62px;
      right: 0px;
      width: 250px;
      padding: 2rem 0;
      transform: translateX(100%);
      margin: 1rem 0;
    }

    .nav-item {
      width: 100%;
    }

    .nav-item--movil {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      align-items: center;
      row-gap: 1rem;
    }

    .nav-link {
      display: block;
      width: 100%;
      text-align: center;
      padding-bottom: 10px;
      border-bottom: solid 1px var(--color-back);
      font-size: 14px;
    }

    .hamburger {
      display: block;
    }

    .menu-tini {
      display: none;
    }
  }
</style>

<script>
  const navEl = document.querySelector(
    ".nav",
  ) as HTMLDivElement;
  const hamburgerEl = document.querySelector(
    ".hamburger",
  ) as HTMLDivElement;

  hamburgerEl.addEventListener("click", () => {
    navEl.classList.toggle("nav-open");
    hamburgerEl.classList.toggle("hamburger-open");
  });

  navEl.addEventListener("click", () => {
    navEl.classList.remove("nav-open");
    hamburgerEl.classList.remove("hamburger-open");
  });
</script>
