---
interface Props{
  href: string,
  messageBtn: string
}

const { href, messageBtn } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noreferrer noopener"
  class="btn">
  {messageBtn}
</a>

<style>
  .btn {
    background-color: var(--color-secondary);
    box-shadow: 0px 4px 4px rgba(0, 0, 0, 0.35);
    border-radius: 10px;
    color: var(--color-text);
    font-family: var(--font-principal);
    font-size: 14px;
    font-weight: 500;
    text-align: center;
    padding: 8px 16px;

    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;

    width: 175px;
    height: 37px;
  }
</style>
