{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "baseUrl": "./",
    "paths": {
      "@components/*":[
        "src/components/*"
      ],
      "@layouts/*":[
        "src/layouts/*"
      ],
      "@icons/*":[
        "src/icons/*"
      ],
      "@lib/*":[
        "src/lib/*"
      ]
    }
  }
}
